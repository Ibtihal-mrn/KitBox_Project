<!-- Choisir les dimensions-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="KitBox_Project.Color"
        Title="KitBox_Project">
    <StackPanel>

        <Button Content="Home" Click="GoToMainWindow" HorizontalAlignment="Left" VerticalAlignment="Top" />

        <TextBlock Text="3. Color of the locker" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24" />
        
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">           
            <Button Background="SaddleBrown" Width="50" Height="50" Click="SelectColor" Tag="Marron"/>
            <Button Background="White" Width="50" Height="50" Click="SelectColor" Tag="White"/>
            <TextBlock x:Name="SelectedColorText" Text="Selected color : White" 
               HorizontalAlignment="Center" FontSize="16" Margin="10"/>
        </StackPanel>
  
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,50,0,0">
            <Button Content="Back" Click="GoToHeight" Margin="5,0"/>
            <Button Content="Next" Click="GoToDoor" Margin="5,0"/>
        </StackPanel>

    </StackPanel>
</Window>
